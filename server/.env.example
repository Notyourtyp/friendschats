# ============================================================
#  COMETCHAT CREDENTIALS  — replace with your actual values
# ============================================================
COMETCHAT_APP_ID=YOUR_COMETCHAT_APP_ID
COMETCHAT_REGION=YOUR_COMETCHAT_REGION        # e.g. us, eu, in
COMETCHAT_API_KEY=YOUR_COMETCHAT_REST_API_KEY  # REST API key (not auth key)

# ============================================================
#  APP SECRET — generate any long random string
# ============================================================
JWT_SECRET=YOUR_SUPER_SECRET_JWT_STRING_HERE

# ============================================================
#  SERVER CONFIG
# ============================================================
PORT=5000
CLIENT_URL=http://localhost:5173
